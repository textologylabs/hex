{
  "name": "{{ app_name }}-db",
  "version": "0.1.0",
  "description": "Postgres data access for {{ app_name }}",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx src/index.dev.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "pg-mem": "^3.0.5",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
